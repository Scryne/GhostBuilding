# ═══════════════════════════════════════════════════════════════════════════
# GhostBuilding — Environment Configuration
# Copy this file to .env and fill in the values.
# ═══════════════════════════════════════════════════════════════════════════

# ── Database Configuration ─────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ghostbuilding

# ── Redis Configuration ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Backend Configuration ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ghostbuilding
SECRET_KEY=change-this-to-a-random-64-char-string-in-production
ENVIRONMENT=dev
DEBUG=false

# ── Frontend Configuration ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── External APIs (Optional — for advanced features) ───────────────────────
GOOGLE_MAPS_API_KEY=
BING_MAPS_API_KEY=
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=
